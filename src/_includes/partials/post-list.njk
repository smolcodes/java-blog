    {% if postListHeadline %}
    <h2 class="post-rec">
      {{ postListHeadline }}
    </h2>
    {% endif %}
     <section>
      <div class="post-content">
        {% for item in postListItems %}
        {% set currentPost = post.data.post %}
					<article class="m-auto border-b border-orange-200 pb-6  {% if item.data.imageURL %} flex justify-between {% endif %}">
          <div>
            <h2>
<a class="no-underline border-none text-lg md:text-2xl text-indigo-600 hover:text-yellow-500" href="{{ item.url }}">{{ item.data.title }} &#x2192;</a></h2>
              <time class="mr-4 block-inline serif h-8 text-md text-indigo-500 font-bold pr-2 pt-1 pb-1" datetime="{{ item.data.date }}"> {{ item.data.date | asPostDate }}</time>
              <p  class="text-slate-500 font-serif text-base md:text-md lg:text-lg mb-5">{{ item.data.description }}</p>
             {% if item.data.tags %}
      {% for tag in item.data.tags %}
          <a class="hover:bg-yellow-100 hover:text-slate-400 hover:border-yellow-400 hover:shadow-lg hover:shadow-orange-400/50 hover:border-2 rounded-xl inline-block text-sm text-indigo-600 ring-1 ring-indigo-600 p-1 hover:text-gray-50" href="/blog/tag/{{ tag | slug }}/">#{{ tag | replace(' ', ' ') | capitalize }}</a>
      {% endfor %}
  {% endif %}
  </div>
 {% if item.data.imageURL %}
  <div class="w-5/12 ml-4">
  <img src="{{ item.data.imageURL }}">
  </div>
  {% endif %}
      </article>
        {% endfor %}
        </div>
     </section>

